<mujoco>
  <compiler angle="radian" assetdir="assets"/>
  <option iterations="3" ls_iterations="5" timestep="0.002" density="1.2" viscosity="0.00002">
    <flag eulerdamp="disable"/>
  </option>
  <visual>
    <global offwidth="800" offheight="600"/>
  </visual>

  <include file="goal_kid.xml"/>

  <asset>
    <texture name="skybox" type="skybox" fileup="backgrounds/kiara_1_dawn_top.png" filedown="backgrounds/kiara_1_dawn_bottom.png" filefront="backgrounds/kiara_1_dawn_front.png" fileback="backgrounds/kiara_1_dawn_back.png" fileleft="backgrounds/kiara_1_dawn_left.png" fileright="backgrounds/kiara_1_dawn_right.png"/>
    <texture name="pitch" file="kid_field.png" type="2d"/>
    <material name="pitch" reflectance="0.0" texture="pitch" texrepeat="1 1" texuniform="false"/>
    <texture name="ball" type="cube" fileup="ball/up.png" filedown="ball/down.png" filefront="ball/front.png" fileback="ball/back.png" fileleft="ball/left.png" fileright="ball/right.png"/>
    <material name="ball" texture="ball"/>
    <model file="pi_plus.xml"/>
  </asset>

  <worldbody>
    <camera name="fixed_default" pos="7.709 -7.854 6.511" xyaxes="0.726 0.687 -0.000 -0.357 0.377 0.855"/>
    <light cutoff="100" diffuse="1 1 1" dir="-0 0 -1.3" directional="true" exponent="1" pos="0 0 1.3" specular=".1 .1 .1"/>
    <geom material="pitch" name="pitch" pos="0 0 0" size="5.5 4 1" type="plane"/>

    <replicate count="{{NUM_ROBOTS}}" sep="_" offset="{{OFFSET}} 0 0">
      <frame pos="1 -3.25 0.0" euler="0 0 1.57">
        <attach model="{{ROBOT_TYPE}}" prefix="robot_"/>
      </frame>
    </replicate>

    <body name="ball" pos="0 0 0.11">
      <freejoint name="ball-root"/>
      <site name='B-vismarker' pos='0 0 0'/>
      <geom name="ball" pos="0 0 0" size="0.07" mass="0.205" friction="0.4 0.01 0.01" rgba="1 1 1 1" condim="6" priority="1" solref="-5000 -20" type="sphere" material="ball"/>
    </body>
  </worldbody>
</mujoco>
