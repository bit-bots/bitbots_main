<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>piplus_description</name>
  <version>2.1.2</version>
  <description>URDF description of the Pi Plus robot.</description>
  <maintainer email="info@bit-bots.de">Hamburg Bit-Bots</maintainer>
  <maintainer email="2krueger@studium.informatik.uni-hamburg.de">Mark Oliver Krüger</maintainer>
  <author email="info@bit-bots.de">Hamburg Bit-Bots</author>
  <license>MIT</license>  


  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>bitbots_docs</depend>
  <depend>bitbots_robot_description</depend>
  <depend>bitbots_parameter_blackboard</depend>
  <depend>bitbots_utils</depend>
  <depend>joint_state_publisher_gui</depend>
  <depend>sensor_msgs</depend>
  <depend>tf2</depend>
  <depend>urdf</depend>
  <depend>xacro</depend>

  <export>
    <bitbots_documentation>
      <status>stable</status>
      <language>xacro</language>
    </bitbots_documentation>
    <build_type>ament_cmake</build_type>
  </export>
</package>
