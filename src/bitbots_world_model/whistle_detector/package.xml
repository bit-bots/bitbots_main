<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>bitbots_whistle_detector</name>
  <version>0.0.0</version>
  <description>The Bitbots Whistle Detector package</description>

  <maintainer email="info@bit-bots.de">Hamburg Bit-Bots</maintainer>

  <license>MIT</license>

  <author email="info@bit-bots.de">Hamburg Bit-Bots</author>

  <buildtool_depend>rosidl_default_generators</buildtool_depend>
  <exec_depend>rosidl_default_runtime</exec_depend>
  <depend>rclpy</depend>
  <depend>std_msgs</depend>
  <depend>std_srvs</depend>
  <test_depend>ament_mypy</test_depend>

  <test_depend>python3-pytest</test_depend>

  <export>
    <bitbots_documentation>
      <language>python3</language>
      <status>unknown</status>
    </bitbots_documentation>
    <build_type>ament_python</build_type>
  </export>

</package>
