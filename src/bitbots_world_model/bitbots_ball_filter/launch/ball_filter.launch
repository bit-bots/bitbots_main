<launch>
    <arg name="sim" default="false"/>
    <arg name="tf_prefix" default=""/>
    <node pkg="bitbots_ball_filter" exec="ball_filter" name="bitbots_ball_filter" output="screen">
        <param name="use_sim_time" value="$(var sim)"/>
        <param name="filter.frame" value="$(var tf_prefix)map"/>
    </node>
</launch>
