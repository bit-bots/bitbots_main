<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>livelybot_serial</name>
  <version>0.0.0</version>
  <description>
    Core hardware communication library for Livelybot robots.
    Manages serial CAN-over-USB protocol, motor control, and joint state publishing.
  </description>
  <maintainer email="info@hightorque-robotics.com">HighTorque Robotics</maintainer>
  <license>Apache-2.0</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>std_msgs</depend>
  <depend>sensor_msgs</depend>
  <depend>livelybot_msg</depend>
  <depend>livelybot_description</depend>
  <depend>bitbots_msgs</depend>
  <depend>std_srvs</depend>
  <depend>diagnostic_updater</depend>
  <depend>serial</depend>

  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>
  <test_depend>ament_cmake_gtest</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
