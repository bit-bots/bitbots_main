<launch>
    <arg name="emergency_button" default="true"/>
    <arg name="listener" default="false"/>
    <arg name="publisher" default="false"/>
    <arg name="robot_ip" default="10.10.10.10"/>

    <group if="$(var emergency_button)">
        <group if ="$(var listener)">
            <node pkg="bitbots_emergency" exec="EMERGENCY_NODE_LISTENER" output="screen"/>
        </group>
        <group if="$(var publisher)">
            <executable cmd="bash $(find-pkg-share bitbots_emergency)/scripts/publisher.sh $(var robot_ip)" output="screen"/>
            <node pkg="bitbots_emergency" exec="EMERGENCY_NODE_PUBLISHER" output="screen"/>
        </group>
    </group>
</launch>
