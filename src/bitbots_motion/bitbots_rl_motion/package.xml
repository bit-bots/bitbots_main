<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>bitbots_rl_motion</name>
  <version>0.1.0</version>
  <description>The bitbots_rl_motion package provides different reinforcement based motions like walking and standing up.</description>
  <maintainer email="git@bit-bots.de">Hamburg Bit-Bots</maintainer>
  <maintainer email="2krueger@studium.informatik.uni-hamburg.de">Mark Oliver Krüger</maintainer>
  <license>MIT</license>

  <test_depend>ament_copyright</test_depend>
  <test_depend>ament_flake8</test_depend>
  <test_depend>ament_pep257</test_depend>
  <test_depend>python3-pytest</test_depend>
  <exec_depend>python3-onnxruntime-pip</exec_depend>
  <exec_depend>std_msgs</exec_depend>
  <exec_depend>bitbots_msgs</exec_depend>
  <exec_depend>sensor_msgs</exec_depend>
  <exec_depend>geometry_msgs</exec_depend>
  <exec_depend>tf2_ros</exec_depend>
  <exec_depend>tf2_geometry_msgs</exec_depend>
  <exec_depend>tf_transformations</exec_depend>
  <exec_depend>bitbots_tf_buffer</exec_depend>
  <exec_depend>ros2_numpy</exec_depend>
  <exec_depend>soccer_vision_3d_msgs</exec_depend>
  <exec_depend>rclpy</exec_depend>

  <export>
    <build_type>ament_python</build_type>
  </export>
</package>
